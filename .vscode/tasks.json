{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C: build active file",
            "type": "shell",
            "command": "C:\\ProgramData\\mingw64\\mingw64\\bin\\gcc.exe",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the active C file with GCC."
        }
    ]
}
